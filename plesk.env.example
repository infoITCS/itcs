# ============================================================
# Plesk Environment Variables
# Add these in: Plesk → Domains → itcs.com.pk → Node.js → Custom environment variables
# Also required BEFORE the first Git deploy build (VITE_* are baked in at build time)
# ============================================================

NODE_ENV=production
PORT=3000

# Database
MONGO_URI=your-mongodb-connection-string

# Auth
JWT_SECRET=your-long-random-jwt-secret-at-least-32-characters
ALLOWED_ADMIN_EMAILS=zulqarnain.hafeez@itcs.com.pk
ALLOWED_ORIGINS=https://itcs.com.pk,https://www.itcs.com.pk

# Frontend build-time variables (required before npm run build)
VITE_BACKEND_URL=
VITE_MSAL_CLIENT_ID=your-msal-client-id
VITE_MSAL_TENANT_ID=your-msal-tenant-id
VITE_MSAL_REDIRECT_PATH=/login
VITE_ALLOWED_ADMIN_EMAILS=zulqarnain.hafeez@itcs.com.pk

# Contact form — Brevo SMTP
CONTACT_EMAIL_TO=info@itcs.com.pk
CONTACT_SMTP_HOST=smtp-relay.brevo.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=your-brevo-login-email
CONTACT_SMTP_PASS=your-brevo-smtp-key

# Job applications — Microsoft 365 / Outlook
HRM_EMAIL_TO=hrm@itcs.com.pk
HRM_SMTP_HOST=smtp.office365.com
HRM_SMTP_PORT=587
HRM_SMTP_USER=hrm@itcs.com.pk
HRM_SMTP_PASS=your-microsoft-365-app-password

# Password reset (Gmail)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password
