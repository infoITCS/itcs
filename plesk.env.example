# ============================================================
# Plesk Environment Variables
# Add these in: Plesk → Domains → your domain → Node.js → Custom environment variables
# Also required BEFORE the first Git deploy build (VITE_* are baked in at build time)
# ============================================================
#
# PLESK NODE.JS SETTINGS (Dashboard)
# ---------------------------------
# Node.js version:        20.x
# Application mode:       production
# Application root:       /httpdocs
# Application startup:    _passenger.cjs   ← required for ESM + Phusion Passenger on Plesk
# Document root:          dist            ← serves built React app; /api/* goes to Node
# Package manager:        npm
#
# After changing startup file or env vars: click "Restart App"
# After Git deploy: Git → Pull → Deploy, then Restart App
#
# TROUBLESHOOTING 504 on /api/health
# ---------------------------------
# 1. Node.js → Run Node.js commands → dropdown: npm → input: run check
#    (or dropdown: node → input: scripts/check-app.js)
# 2. Ensure npm run build completed (dist/ folder must exist)
# 3. Check Node.js error log in Plesk for crash messages
# 4. ALLOWED_ORIGINS must include your live domain (see below)
#
# ============================================================

NODE_ENV=production
PORT=3000

# Database
MONGO_URI=your-mongodb-connection-string

# Auth
JWT_SECRET=your-long-random-jwt-secret-at-least-32-characters
ALLOWED_ADMIN_EMAILS=zulqarnain.hafeez@itcs.com.pk
ALLOWED_ORIGINS=https://itcs.com.pk,https://www.itcs.com.pk,https://recursing-blackwell.72-61-114-141.plesk.page,http://recursing-blackwell.72-61-114-141.plesk.page

# Frontend build-time variables (required before npm run build)
VITE_BACKEND_URL=
VITE_MSAL_CLIENT_ID=your-msal-client-id
VITE_MSAL_TENANT_ID=your-msal-tenant-id
VITE_MSAL_REDIRECT_PATH=/login
VITE_ALLOWED_ADMIN_EMAILS=zulqarnain.hafeez@itcs.com.pk

# Contact form — Brevo SMTP
CONTACT_EMAIL_TO=info@itcs.com.pk
CONTACT_SMTP_HOST=smtp-relay.brevo.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=your-brevo-login-email
CONTACT_SMTP_PASS=your-brevo-smtp-key

# Job applications — Microsoft 365 / Outlook
HRM_EMAIL_TO=hrm@itcs.com.pk
HRM_SMTP_HOST=smtp.office365.com
HRM_SMTP_PORT=587
HRM_SMTP_USER=hrm@itcs.com.pk
HRM_SMTP_PASS=your-microsoft-365-app-password

# Password reset (Gmail)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password
