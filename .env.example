# Backend
MONGO_URI=your-mongodb-connection-string
# Use a long random string (32+ characters) in production
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
PORT=5000
ALLOWED_ADMIN_EMAILS=admin@itcs.com.pk
# Comma-separated frontend origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000,https://itcs.com.pk,https://www.itcs.com.pk

# Gmail (password reset)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password

# Contact form — Brevo SMTP
CONTACT_EMAIL_TO=info@itcs.com.pk
CONTACT_SMTP_HOST=smtp-relay.brevo.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=your-brevo-login-email
CONTACT_SMTP_PASS=your-brevo-smtp-key

# Job applications — Microsoft 365 / Outlook
HRM_EMAIL_TO=hrm@itcs.com.pk
HRM_SMTP_HOST=smtp.office365.com
HRM_SMTP_PORT=587
HRM_SMTP_USER=hrm@itcs.com.pk
HRM_SMTP_PASS=your-microsoft-365-app-password

# Frontend
# Optional. Leave empty in production to use same-origin /api routes.
VITE_BACKEND_URL=
VITE_DEVTO_API_BASE=https://dev.to/api
VITE_DEVTO_ORG=itcs11
VITE_MSAL_CLIENT_ID=your-client-id
VITE_MSAL_TENANT_ID=your-tenant-id
VITE_MSAL_REDIRECT_PATH=/login
